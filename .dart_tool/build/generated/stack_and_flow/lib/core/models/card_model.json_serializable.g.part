_$CardModelImpl _$$CardModelImplFromJson(Map<String, dynamic> json) =>
    _$CardModelImpl(
      id: json['id'] as String,
      rank: $enumDecode(_$RankEnumMap, json['rank']),
      suit: $enumDecode(_$SuitEnumMap, json['suit']),
      jokerDeclaredSuit:
          $enumDecodeNullable(_$SuitEnumMap, json['jokerDeclaredSuit']),
      jokerDeclaredRank:
          $enumDecodeNullable(_$RankEnumMap, json['jokerDeclaredRank']),
    );

Map<String, dynamic> _$$CardModelImplToJson(_$CardModelImpl instance) =>
    <String, dynamic>{
      'id': instance.id,
      'rank': _$RankEnumMap[instance.rank]!,
      'suit': _$SuitEnumMap[instance.suit]!,
      'jokerDeclaredSuit': _$SuitEnumMap[instance.jokerDeclaredSuit],
      'jokerDeclaredRank': _$RankEnumMap[instance.jokerDeclaredRank],
    };

const _$RankEnumMap = {
  Rank.two: 'two',
  Rank.three: 'three',
  Rank.four: 'four',
  Rank.five: 'five',
  Rank.six: 'six',
  Rank.seven: 'seven',
  Rank.eight: 'eight',
  Rank.nine: 'nine',
  Rank.ten: 'ten',
  Rank.jack: 'jack',
  Rank.queen: 'queen',
  Rank.king: 'king',
  Rank.ace: 'ace',
  Rank.joker: 'joker',
};

const _$SuitEnumMap = {
  Suit.spades: 'spades',
  Suit.clubs: 'clubs',
  Suit.hearts: 'hearts',
  Suit.diamonds: 'diamonds',
};
