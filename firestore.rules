rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Public aggregate: concurrent game-server WebSocket connections (written by server only).
    match /metadata/online_count {
      allow read: if true;
      allow write: if false;
    }

    // User profiles: owner writes (displayName, avatarUrl); any signed-in user
    // can read public fields (for friends / in-game profile sheets).
    match /users/{uid} {
      allow read: if request.auth != null;

      allow create, update: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.keys().hasOnly([
          'displayName',
          'avatarUrl',
          'updatedAt',
          'profileLastChangedAt',
        ]);
    }

    // Accepted friendships (each user has a doc per friend).
    // Create only when a pending incoming request exists (accept flow), so
    // users cannot self-add under another user's friends without consent.
    match /users/{uid}/friends/{friendUid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null && (
        (
          request.auth.uid == uid
          && exists(/databases/$(database)/documents/users/$(uid)/incomingFriendRequests/$(friendUid))
        )
        || (
          request.auth.uid == friendUid
          && exists(/databases/$(database)/documents/users/$(friendUid)/incomingFriendRequests/$(uid))
        )
      );
      allow delete: if request.auth != null
        && (request.auth.uid == uid || request.auth.uid == friendUid);
    }

    // Incoming friend request: only [fromUid] may create/update their doc; recipient or sender may delete.
    // (set() on an existing request is an update, not create — both must be allowed.)
    match /users/{uid}/incomingFriendRequests/{fromUid} {
      allow create, update: if request.auth != null && request.auth.uid == fromUid;
      allow read: if request.auth != null
        && (request.auth.uid == uid || request.auth.uid == fromUid);
      allow delete: if request.auth != null
        && (request.auth.uid == uid || request.auth.uid == fromUid);
    }

    // In-app room invites (recipient sees list; host creates with their uid).
    match /users/{uid}/gameInvites/{inviteId} {
      allow create: if request.auth != null
        && request.resource.data.fromUid == request.auth.uid
        && request.resource.data.keys().hasOnly([
          'fromUid',
          'fromDisplayName',
          'roomCode',
          'createdAt',
        ]);
      allow read: if request.auth != null && request.auth.uid == uid;
      allow delete: if request.auth != null
        && (request.auth.uid == uid
          || resource.data.fromUid == request.auth.uid);
    }

    // Leaderboards: allow authenticated reads, only server can write.
    match /ranked_stats/{uid} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /ranked_hardcore_stats/{uid} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /leaderboard_single_player/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
    match /leaderboard_online/{uid} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /leaderboard_tournament_ai/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
    match /leaderboard_tournament_online/{uid} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /leaderboard_bust_offline/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
    match /leaderboard_bust_online/{uid} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
