rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Public aggregate: concurrent game-server WebSocket connections (written by server only).
    match /metadata/online_count {
      allow read: if true;
      allow write: if false;
    }

    // User profiles: self read/write only. Final document may only contain
    // fields set by FirestoreProfileService (displayName, avatarUrl, timestamps).
    // Using keys() instead of writeFields: writeFields can be null in some
    // emulator/client paths and triggers a rules evaluation error.
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;

      allow create, update: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.keys().hasOnly([
          'displayName',
          'avatarUrl',
          'updatedAt',
          'profileLastChangedAt',
        ]);
    }

    // Leaderboards: allow authenticated reads, only server can write.
    match /ranked_stats/{uid} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /ranked_hardcore_stats/{uid} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /leaderboard_single_player/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
    match /leaderboard_online/{uid} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /leaderboard_tournament_ai/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
    match /leaderboard_tournament_online/{uid} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /leaderboard_bust_offline/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
    match /leaderboard_bust_online/{uid} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
