rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Client version hints (optional in-app “update available” banner). Admin-only writes via Console.
    match /app_config/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Public aggregate: concurrent game-server WebSocket connections (written by server only).
    match /metadata/online_count {
      allow read: if true;
      allow write: if false;
    }

    // User profiles: owner writes; any signed-in user can read public fields
    // (friends / in-game profile sheets). After merge, the document may only
    // contain these keys (see FirestoreProfileService).
    match /users/{uid} {
      allow read: if request.auth != null;

      allow create, update: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.keys().hasOnly([
          'displayName',
          'displayNameKey',
          'avatarUrl',
          'updatedAt',
          'profileLastChangedAt',
          'cardBackSelectedId',
          'jokerCoverSelectedId',
          'cardFaceSet',
          'reactionWheel',
          'fcmTokens',
        ]);

      allow delete: if request.auth != null && request.auth.uid == uid;
    }

    // Unique public display names (one doc per normalized name).
    match /display_name_registry/{nameKey} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasOnly([
          'uid',
          'displayName',
          'updatedAt',
        ]);
      allow update: if request.auth != null
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasOnly([
          'uid',
          'displayName',
          'updatedAt',
        ]);
      allow delete: if request.auth != null
        && resource.data.uid == request.auth.uid;
    }

    // Accepted friendships (each user has a doc per friend).
    // Create only when a pending incoming request exists (accept flow), so
    // users cannot self-add under another user's friends without consent.
    match /users/{uid}/friends/{friendUid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null && (
        (
          request.auth.uid == uid
          && exists(/databases/$(database)/documents/users/$(uid)/incomingFriendRequests/$(friendUid))
        )
        || (
          request.auth.uid == friendUid
          && exists(/databases/$(database)/documents/users/$(friendUid)/incomingFriendRequests/$(uid))
        )
      );
      allow delete: if request.auth != null
        && (request.auth.uid == uid || request.auth.uid == friendUid);
    }

    // Incoming friend request: only [fromUid] may create/update their doc; recipient or sender may delete.
    // (set() on an existing request is an update, not create — both must be allowed.)
    match /users/{uid}/incomingFriendRequests/{fromUid} {
      allow create, update: if request.auth != null && request.auth.uid == fromUid;
      allow read: if request.auth != null
        && (request.auth.uid == uid || request.auth.uid == fromUid);
      allow delete: if request.auth != null
        && (request.auth.uid == uid || request.auth.uid == fromUid);
    }

    // In-app room invites (recipient sees list; host creates with their uid).
    match /users/{uid}/gameInvites/{inviteId} {
      allow create: if request.auth != null
        && request.resource.data.fromUid == request.auth.uid
        && request.resource.data.keys().hasOnly([
          'fromUid',
          'fromDisplayName',
          'roomCode',
          'createdAt',
        ]);
      allow read: if request.auth != null && request.auth.uid == uid;
      allow delete: if request.auth != null
        && (request.auth.uid == uid
          || resource.data.fromUid == request.auth.uid);
    }

    // In-app notification inbox. Written server-side only (game server /
    // future Cloud Functions use the Admin SDK, which bypasses these rules)
    // — clients may only read their own, mark as read, or delete.
    match /users/{uid}/notifications/{notificationId} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null && request.auth.uid == uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if request.auth != null && request.auth.uid == uid;
    }

    // Blocked users: owner-only, one doc per blocked uid.
    match /users/{uid}/blockedUsers/{blockedUid} {
      allow read, create, delete: if request.auth != null && request.auth.uid == uid;
    }

    // User reports (abuse/report-message flow). Create-only from the client;
    // review happens out-of-band (Firestore console / future Cloud Function),
    // so no client read/update/delete.
    match /reports/{reportId} {
      allow create: if request.auth != null
        && request.resource.data.reporterUid == request.auth.uid;
      allow read, update, delete: if false;
    }

    // Leaderboards: allow authenticated reads, only server can write.
    match /ranked_stats/{uid} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /ranked_hardcore_stats/{uid} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /leaderboard_single_player/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
    match /leaderboard_online/{uid} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /leaderboard_tournament_ai/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
    // Multi-round online tournament outcomes are recorded by the client
    // (TournamentCoordinator), same ownership model as tournament_ai.
    match /leaderboard_tournament_online/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
    match /leaderboard_bust_offline/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
    match /leaderboard_bust_online/{uid} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    // Longest-combo record leaderboard (cross-mode). Client-writable like the
    // other offline-derived boards — the client only ever raises its own
    // record (see ComboLeaderboardWriter), never someone else's.
    match /leaderboard_combos/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Lifetime head-to-head between two Firebase accounts (server writes only).
    match /matchups/{pairId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
