# Copy to key.properties and fill in. key.properties is gitignored.
# Keystore (see Flutter: https://docs.flutter.dev/deployment/android#signing-the-app)
#
# storeFile: path relative to this android/ folder, e.g. upload-keystore.p12
# Or use an absolute path.
#
storePassword=
keyPassword=
keyAlias=upload
storeFile=upload-keystore.p12
