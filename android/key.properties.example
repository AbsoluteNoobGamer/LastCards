# Copy this file to key.properties (same folder as this example) and fill in
# your release keystore. key.properties is gitignored.
#
# Generate a keystore (one-time), then:
#   storePassword=<keystore password>
#   keyPassword=<key password>
#   keyAlias=<your key alias>
#   storeFile=<path to .jks or .keystore, use forward slashes>
#
# Example (Windows):
#   storeFile=C:/Users/you/keys/lastcards-release.jks
#
# See: https://docs.flutter.dev/deployment/android#signing-the-app

storePassword=
keyPassword=
keyAlias=
storeFile=
